# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Spark
.spark-warehouse/
metastore_db/
derby.log

# Logs (regenerated on every run)
logs/*.log

# Spark's own processed-data output is regenerated by main.py on every run --
# keep the folder, not its contents.
data/processed/*
!data/processed/.gitkeep

# OS / editor noise
.DS_Store
.idea/
.vscode/

# Note: data/raw/retail_sales_raw.csv and reports/*.csv are intentionally
# NOT ignored -- they're part of this portfolio project's deliverable, so
# anyone cloning the repo can see real output without running the pipeline.
